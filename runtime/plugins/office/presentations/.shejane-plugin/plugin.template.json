{
  "schema_version": 1,
  "id": "org.shejane.presentations",
  "version": "__PLUGIN_VERSION__",
  "name": "Presentations",
  "description": "Read, create, edit, and render PPTX presentations with explicit layout and degradation records.",
  "license": "AGPL-3.0-only",
  "publisher": {"id": "org.shejane", "name": "SheJane"},
  "runtime": {
    "min_version": "0.1.0",
    "execution": {
      "kind": "managed_worker",
      "entrypoint": "__ENTRYPOINT__",
      "platforms": ["__PLATFORM__"],
      "runtime_assets": [
        {"id": "org.libreoffice.runtime", "version": "25.8.7", "digest": "__RUNTIME_ASSET_DIGEST__"}
      ]
    }
  },
  "contributions": {
    "actions": [
      {
        "id": "presentation.read", "title": "Read presentation",
        "description": "Read bounded slide structure, text, images, tables, notes, layout, and unsupported features.",
        "input_schema": "actions/presentation.read.input.json", "output_schema": "actions/presentation.read.output.json",
        "consumes": ["application/vnd.openxmlformats-officedocument.presentationml.presentation"], "produces": [],
        "effects": ["read"], "determinism": "input_stable", "capabilities": ["input.read"],
        "limits": {"timeout_ms": 30000, "memory_mb": 1024, "output_mb": 8}
      },
      {
        "id": "presentation.create", "title": "Create presentation",
        "description": "Create a PPTX from explicit slides, an optional authorized template, and authorized images.",
        "input_schema": "actions/presentation.create.input.json", "output_schema": "actions/presentation.create.output.json",
        "consumes": ["application/vnd.openxmlformats-officedocument.presentationml.presentation", "image/png", "image/jpeg", "image/gif"],
        "produces": ["application/vnd.openxmlformats-officedocument.presentationml.presentation"],
        "effects": ["read", "artifact"], "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 60000, "memory_mb": 1024, "output_mb": 256}
      },
      {
        "id": "presentation.edit", "title": "Edit presentation",
        "description": "Apply bounded slide, text, table, and image edits to a copy of an authorized PPTX input.",
        "input_schema": "actions/presentation.edit.input.json", "output_schema": "actions/presentation.edit.output.json",
        "consumes": ["application/vnd.openxmlformats-officedocument.presentationml.presentation", "image/png", "image/jpeg", "image/gif"],
        "produces": ["application/vnd.openxmlformats-officedocument.presentationml.presentation"],
        "effects": ["read", "artifact"], "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 60000, "memory_mb": 1024, "output_mb": 256}
      },
      {
        "id": "presentation.render", "title": "Render presentation",
        "description": "Render an authorized PPTX to PDF and bounded PNG slide previews with explicit degradation warnings.",
        "input_schema": "actions/presentation.render.input.json", "output_schema": "actions/presentation.render.output.json",
        "consumes": ["application/vnd.openxmlformats-officedocument.presentationml.presentation"],
        "produces": ["application/pdf", "image/png"],
        "effects": ["read", "artifact"], "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 300000, "memory_mb": 2048, "output_mb": 512}
      }
    ],
    "commands": [
      {"id": "read", "title": "Read presentation", "description": "Read a PPTX as structured slides.", "instructions": "commands/read.md", "required_actions": ["presentation.read"]},
      {"id": "create", "title": "Create presentation", "description": "Create a PPTX Artifact.", "instructions": "commands/create.md", "required_actions": ["presentation.create"]},
      {"id": "edit", "title": "Edit presentation", "description": "Edit a PPTX without changing the original.", "instructions": "commands/edit.md", "required_actions": ["presentation.edit"]},
      {"id": "render", "title": "Render presentation", "description": "Render a PPTX to PDF and slide previews.", "instructions": "commands/render.md", "required_actions": ["presentation.render"]}
    ]
  }
}
