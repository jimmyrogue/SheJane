{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false, "required": ["filename", "slides"],
  "properties": {
    "filename": {"type": "string", "minLength": 6, "maxLength": 255, "pattern": "^[^/\\\\]+\\.pptx$"},
    "template_input_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "slides": {"type": "array", "minItems": 1, "maxItems": 200, "items": {"$ref": "#/$defs/slide"}}
  },
  "$defs": {
    "text": {"type": "string", "maxLength": 10000},
    "font_name": {"type": "string", "minLength": 1, "maxLength": 200},
    "coordinate": {"type": "number", "minimum": 0, "maximum": 100},
    "extent": {"type": "number", "exclusiveMinimum": 0, "maximum": 100},
    "bullet": {
      "type": "object", "additionalProperties": false, "required": ["text"],
      "properties": {
        "text": {"$ref": "#/$defs/text"}, "level": {"type": "integer", "minimum": 0, "maximum": 8},
        "font_name": {"$ref": "#/$defs/font_name"}, "font_size": {"type": "number", "minimum": 1, "maximum": 400}
      }
    },
    "text_box": {
      "type": "object", "additionalProperties": false,
      "required": ["text", "left", "top", "width", "height"],
      "properties": {
        "text": {"$ref": "#/$defs/text"}, "left": {"$ref": "#/$defs/coordinate"},
        "top": {"$ref": "#/$defs/coordinate"}, "width": {"$ref": "#/$defs/extent"},
        "height": {"$ref": "#/$defs/extent"}, "font_name": {"$ref": "#/$defs/font_name"},
        "font_size": {"type": "number", "minimum": 1, "maximum": 400}
      }
    },
    "table": {
      "type": "object", "additionalProperties": false,
      "required": ["rows", "left", "top", "width", "height"],
      "properties": {
        "rows": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/$defs/text"}}},
        "left": {"$ref": "#/$defs/coordinate"}, "top": {"$ref": "#/$defs/coordinate"},
        "width": {"$ref": "#/$defs/extent"}, "height": {"$ref": "#/$defs/extent"}
      }
    },
    "image": {
      "type": "object", "additionalProperties": false,
      "required": ["input_id", "left", "top", "width"],
      "properties": {
        "input_id": {"type": "string", "minLength": 1, "maxLength": 100},
        "left": {"$ref": "#/$defs/coordinate"}, "top": {"$ref": "#/$defs/coordinate"},
        "width": {"$ref": "#/$defs/extent"}, "height": {"$ref": "#/$defs/extent"}
      }
    },
    "slide": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "layout": {"type": "string", "minLength": 1, "maxLength": 200},
        "title": {"$ref": "#/$defs/text"}, "subtitle": {"$ref": "#/$defs/text"},
        "notes": {"type": "string", "maxLength": 50000}, "font_name": {"$ref": "#/$defs/font_name"},
        "bullets": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/bullet"}},
        "text_boxes": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/text_box"}},
        "tables": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/table"}},
        "images": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/image"}}
      }
    }
  }
}
