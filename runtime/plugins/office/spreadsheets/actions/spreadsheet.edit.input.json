{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["input_id", "operations"],
  "properties": {
    "input_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "output_filename": {"type": "string", "minLength": 6, "maxLength": 255, "pattern": "^[^/\\\\]+\\.xlsx$"},
    "operations": {
      "type": "array", "minItems": 1, "maxItems": 128,
      "items": {
        "oneOf": [
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "range", "values"],
            "properties": {
              "type": {"const": "set_cells"}, "sheet": {"$ref": "#/$defs/sheet"},
              "range": {"$ref": "#/$defs/range"},
              "values": {"$ref": "#/$defs/rows"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "cell", "formula"],
            "properties": {
              "type": {"const": "set_formula"}, "sheet": {"$ref": "#/$defs/sheet"},
              "cell": {"$ref": "#/$defs/cell_ref"},
              "formula": {"type": "string", "minLength": 2, "maxLength": 8192, "pattern": "^="}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "range", "style"],
            "properties": {
              "type": {"const": "format_range"}, "sheet": {"$ref": "#/$defs/sheet"},
              "range": {"$ref": "#/$defs/range"}, "style": {"$ref": "#/$defs/style"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "range"],
            "properties": {
              "type": {"enum": ["merge_cells", "unmerge_cells"]},
              "sheet": {"$ref": "#/$defs/sheet"}, "range": {"$ref": "#/$defs/range"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "rows"],
            "properties": {
              "type": {"const": "append_rows"}, "sheet": {"$ref": "#/$defs/sheet"},
              "rows": {"$ref": "#/$defs/rows"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "row"],
            "properties": {
              "type": {"const": "insert_rows"}, "sheet": {"$ref": "#/$defs/sheet"},
              "row": {"type": "integer", "minimum": 1, "maximum": 1048576},
              "amount": {"type": "integer", "minimum": 1, "maximum": 1000},
              "rows": {"$ref": "#/$defs/rows"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["type", "chart"],
            "properties": {
              "type": {"const": "add_chart"}, "sheet": {"$ref": "#/$defs/sheet"},
              "chart": {"$ref": "#/$defs/chart"}
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "scalar": {"type": ["string", "number", "integer", "boolean", "null"]},
    "sheet": {"type": "string", "minLength": 1, "maxLength": 31},
    "cell_ref": {"type": "string", "pattern": "^[A-Za-z]{1,3}[1-9][0-9]{0,6}$"},
    "range": {"type": "string", "pattern": "^[A-Za-z]{1,3}[1-9][0-9]{0,6}(?::[A-Za-z]{1,3}[1-9][0-9]{0,6})?$"},
    "rows": {"type": "array", "minItems": 1, "maxItems": 10000, "items": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/scalar"}}},
    "color": {"type": "string", "pattern": "^#?(?:[0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$"},
    "style": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {
        "bold": {"type": "boolean"}, "italic": {"type": "boolean"},
        "font_size": {"type": "number", "minimum": 1, "maximum": 409},
        "font_color": {"$ref": "#/$defs/color"}, "fill_color": {"$ref": "#/$defs/color"},
        "horizontal": {"enum": ["left", "center", "right"]},
        "number_format": {"type": "string", "maxLength": 1000}
      }
    },
    "chart": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "data_range", "anchor"],
      "properties": {
        "type": {"enum": ["bar", "line", "pie"]}, "title": {"type": "string", "maxLength": 1000},
        "data_range": {"$ref": "#/$defs/range"}, "categories_range": {"$ref": "#/$defs/range"},
        "anchor": {"$ref": "#/$defs/cell_ref"}, "titles_from_data": {"type": "boolean"}
      }
    }
  }
}
