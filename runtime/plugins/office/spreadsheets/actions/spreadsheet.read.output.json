{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["sheets", "sheet", "requested_range", "range", "values", "formulas", "types", "number_formats", "markdown", "truncated", "timezone_policy", "numeric_policy", "warnings"],
  "properties": {
    "sheets": {
      "type": "array", "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "max_row", "max_column"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "maxLength": 31},
          "max_row": {"type": "integer", "minimum": 1, "maximum": 1048576},
          "max_column": {"type": "integer", "minimum": 1, "maximum": 16384}
        }
      }
    },
    "sheet": {"type": "string", "minLength": 1, "maxLength": 31},
    "requested_range": {"type": "string", "maxLength": 50},
    "range": {"type": "string", "maxLength": 50},
    "values": {"$ref": "#/$defs/value_grid"},
    "formulas": {"$ref": "#/$defs/formula_grid"},
    "types": {"$ref": "#/$defs/type_grid"},
    "number_formats": {"$ref": "#/$defs/string_grid"},
    "markdown": {"type": "string", "maxLength": 60000},
    "truncated": {"type": "boolean"},
    "timezone_policy": {"const": "UTC"},
    "numeric_policy": {"const": "IEEE-754 binary64"},
    "warnings": {"type": "array", "maxItems": 100, "items": {"type": "string", "maxLength": 500}}
  },
  "$defs": {
    "scalar": {"type": ["string", "number", "integer", "boolean", "null"]},
    "value_grid": {"type": "array", "maxItems": 10000, "items": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/scalar"}}},
    "formula_grid": {"type": "array", "maxItems": 10000, "items": {"type": "array", "maxItems": 10000, "items": {"type": ["string", "null"], "maxLength": 8192}}},
    "type_grid": {"type": "array", "maxItems": 10000, "items": {"type": "array", "maxItems": 10000, "items": {"enum": ["empty", "string", "number", "boolean", "date", "datetime", "time", "error", "formula"]}}},
    "string_grid": {"type": "array", "maxItems": 10000, "items": {"type": "array", "maxItems": 10000, "items": {"type": "string", "maxLength": 1000}}}
  }
}
