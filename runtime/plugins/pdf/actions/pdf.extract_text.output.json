{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["page_count", "pages", "ocr_required_pages", "artifact_name"],
  "properties": {
    "page_count": {"type": "integer", "minimum": 1, "maximum": 100000},
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["page_number", "text", "truncated"],
        "properties": {
          "page_number": {"type": "integer", "minimum": 1, "maximum": 100000},
          "text": {"type": "string", "maxLength": 200000},
          "truncated": {"type": "boolean"}
        }
      }
    },
    "ocr_required_pages": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 20,
      "items": {"type": "integer", "minimum": 1, "maximum": 100000}
    },
    "artifact_name": {
      "type": ["string", "null"],
      "pattern": "^pages-[0-9]{4,6}-[0-9]{4,6}\\.txt$"
    }
  }
}
