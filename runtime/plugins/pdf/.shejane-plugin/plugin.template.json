{
  "schema_version": 1,
  "id": "org.shejane.pdf",
  "version": "__PLUGIN_VERSION__",
  "name": "PDF",
  "description": "Inspect PDFs, extract explicit page windows, and render selected pages with a pinned MuPDF Runtime Asset.",
  "license": "AGPL-3.0-only",
  "publisher": {"id": "org.shejane", "name": "SheJane"},
  "runtime": {
    "min_version": "0.1.0",
    "execution": {
      "kind": "managed_worker",
      "entrypoint": "__ENTRYPOINT__",
      "platforms": ["__PLATFORM__"],
      "runtime_assets": [
        {
          "id": "org.mupdf.runtime",
          "version": "1.27.2+shejane.1",
          "digest": "__RUNTIME_ASSET_DIGEST__"
        }
      ]
    }
  },
  "contributions": {
    "actions": [
      {
        "id": "pdf.inspect",
        "title": "Inspect PDF",
        "description": "Read bounded page-count and encryption state from an authorized PDF.",
        "input_schema": "actions/pdf.inspect.input.json",
        "output_schema": "actions/pdf.inspect.output.json",
        "consumes": ["application/pdf"],
        "produces": [],
        "effects": ["read"],
        "determinism": "input_stable",
        "capabilities": ["input.read"],
        "limits": {"timeout_ms": 30000, "memory_mb": 512, "output_mb": 4}
      },
      {
        "id": "pdf.extract_text",
        "title": "Extract PDF text",
        "description": "Extract a bounded, explicit page window without implicit OCR.",
        "input_schema": "actions/pdf.extract_text.input.json",
        "output_schema": "actions/pdf.extract_text.output.json",
        "consumes": ["application/pdf"],
        "produces": ["text/plain"],
        "effects": ["read", "artifact"],
        "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 120000, "memory_mb": 1024, "output_mb": 32}
      },
      {
        "id": "pdf.render_pages",
        "title": "Render PDF pages",
        "description": "Render at most sixteen explicitly selected pages to PNG.",
        "input_schema": "actions/pdf.render_pages.input.json",
        "output_schema": "actions/pdf.render_pages.output.json",
        "consumes": ["application/pdf"],
        "produces": ["image/png"],
        "effects": ["read", "artifact"],
        "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 300000, "memory_mb": 1024, "output_mb": 256}
      }
    ],
    "commands": [
      {
        "id": "inspect",
        "title": "Inspect PDF",
        "description": "Report page count and encryption state for a selected PDF.",
        "instructions": "commands/inspect.md",
        "required_actions": ["pdf.inspect"]
      },
      {
        "id": "text",
        "title": "Extract PDF text",
        "description": "Extract text from an explicit bounded page window.",
        "instructions": "commands/text.md",
        "required_actions": ["pdf.extract_text"]
      },
      {
        "id": "pages",
        "title": "Render PDF pages",
        "description": "Render explicitly selected PDF pages as PNG Artifacts.",
        "instructions": "commands/pages.md",
        "required_actions": ["pdf.render_pages"]
      }
    ]
  }
}
