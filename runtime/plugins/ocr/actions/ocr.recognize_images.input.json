{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input_ids",
    "minimum_confidence",
    "max_lines",
    "max_characters",
    "include_text_artifact",
    "include_json_artifact"
  ],
  "properties": {
    "input_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 100}
    },
    "minimum_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "max_lines": {"type": "integer", "minimum": 1, "maximum": 10000},
    "max_characters": {"type": "integer", "minimum": 1, "maximum": 200000},
    "include_text_artifact": {"type": "boolean"},
    "include_json_artifact": {"type": "boolean"}
  }
}
