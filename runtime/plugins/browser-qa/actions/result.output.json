{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "state_id": {"type": "string"},
    "url": {"type": "string"},
    "title": {"type": "string"},
    "text": {"type": "string"},
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "role", "name"],
        "properties": {
          "ref": {"type": "string"},
          "role": {"type": "string"},
          "name": {"type": "string"}
        }
      }
    },
    "console": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "text"],
        "properties": {"type": {"type": "string"}, "text": {"type": "string"}}
      }
    },
    "network": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "url"],
        "properties": {
          "method": {"type": "string"},
          "url": {"type": "string"},
          "status": {"type": "integer"},
          "failure": {"type": "string"}
        }
      }
    },
    "images": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["base64", "mime_type"],
        "properties": {
          "base64": {"type": "string"},
          "mime_type": {"const": "image/png"}
        }
      }
    },
    "closed": {"type": "boolean"}
  }
}
