{
  "schema_version": 1,
  "id": "org.shejane.media-foundation",
  "version": "__PLUGIN_VERSION__",
  "name": "Media Foundation",
  "description": "Inspect media, render thumbnails and frames, and extract audio with a pinned FFmpeg Runtime Asset.",
  "license": "AGPL-3.0-only",
  "publisher": {"id": "org.shejane", "name": "SheJane"},
  "runtime": {
    "min_version": "0.1.0",
    "execution": {
      "kind": "managed_worker",
      "entrypoint": "__ENTRYPOINT__",
      "platforms": ["__PLATFORM__"],
      "runtime_assets": [
        {
          "id": "org.ffmpeg.runtime",
          "version": "8.1.2+shejane.1",
          "digest": "__RUNTIME_ASSET_DIGEST__"
        }
      ]
    }
  },
  "contributions": {
    "actions": [
      {
        "id": "media.probe",
        "title": "Inspect media",
        "description": "Read bounded container and stream metadata from an authorized media file.",
        "input_schema": "actions/media.probe.input.json",
        "output_schema": "actions/media.probe.output.json",
        "consumes": ["video/mp4", "video/quicktime", "video/webm", "video/x-matroska", "audio/mpeg", "audio/mp4", "audio/wav", "audio/flac", "image/jpeg", "image/png", "image/webp"],
        "produces": [],
        "effects": ["read"],
        "determinism": "input_stable",
        "capabilities": ["input.read"],
        "limits": {"timeout_ms": 30000, "memory_mb": 512, "output_mb": 4}
      },
      {
        "id": "media.thumbnail",
        "title": "Create thumbnail",
        "description": "Render one bounded PNG thumbnail at an explicit timestamp.",
        "input_schema": "actions/media.thumbnail.input.json",
        "output_schema": "actions/media.thumbnail.output.json",
        "consumes": ["video/mp4", "video/quicktime", "video/webm", "video/x-matroska", "image/jpeg", "image/png", "image/webp"],
        "produces": ["image/png"],
        "effects": ["read", "artifact"],
        "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 60000, "memory_mb": 1024, "output_mb": 32}
      },
      {
        "id": "media.extract_frames",
        "title": "Extract frames",
        "description": "Render bounded PNG frames at explicit timestamps.",
        "input_schema": "actions/media.extract_frames.input.json",
        "output_schema": "actions/media.extract_frames.output.json",
        "consumes": ["video/mp4", "video/quicktime", "video/webm", "video/x-matroska"],
        "produces": ["image/png"],
        "effects": ["read", "artifact"],
        "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 300000, "memory_mb": 1024, "output_mb": 256}
      },
      {
        "id": "media.extract_audio",
        "title": "Extract audio",
        "description": "Extract one explicit audio stream to bounded WAV or FLAC output.",
        "input_schema": "actions/media.extract_audio.input.json",
        "output_schema": "actions/media.extract_audio.output.json",
        "consumes": ["video/mp4", "video/quicktime", "video/webm", "video/x-matroska", "audio/mpeg", "audio/mp4", "audio/wav", "audio/flac"],
        "produces": ["audio/wav", "audio/flac"],
        "effects": ["read", "artifact"],
        "determinism": "input_stable",
        "capabilities": ["input.read", "artifact.write"],
        "limits": {"timeout_ms": 300000, "memory_mb": 1024, "output_mb": 512}
      }
    ],
    "commands": [
      {
        "id": "inspect",
        "title": "Inspect media",
        "description": "Inspect an attached media file and report its streams and duration.",
        "instructions": "commands/inspect.md",
        "required_actions": ["media.probe"]
      },
      {
        "id": "thumbnail",
        "title": "Create thumbnail",
        "description": "Create a thumbnail from an attached image or video.",
        "instructions": "commands/thumbnail.md",
        "required_actions": ["media.thumbnail"]
      },
      {
        "id": "frames",
        "title": "Extract frames",
        "description": "Extract frames from a video at explicit timestamps.",
        "instructions": "commands/frames.md",
        "required_actions": ["media.extract_frames"]
      },
      {
        "id": "audio",
        "title": "Extract audio",
        "description": "Extract one audio stream for transcription or reuse.",
        "instructions": "commands/audio.md",
        "required_actions": ["media.extract_audio"]
      }
    ]
  }
}
