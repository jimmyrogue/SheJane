{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:shejane:schema:plugin-action-input:v1",
  "title": "SheJane Plugin Action Invocation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invocation_id",
    "operation_id",
    "action",
    "arguments",
    "inputs",
    "grants",
    "limits",
    "environment"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "invocation_id": {
      "$ref": "#/$defs/invocationId"
    },
    "operation_id": {
      "$ref": "#/$defs/operationId"
    },
    "action": {
      "$ref": "#/$defs/actionReference"
    },
    "arguments": {
      "type": "object"
    },
    "inputs": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/inputFile"
      }
    },
    "grants": {
      "$ref": "#/$defs/grants"
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "model_binding_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    }
  },
  "$defs": {
    "invocationId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "operationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "pluginId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
    },
    "localId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "maxLength": 100,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "mimeType": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}$"
    },
    "inputPath": {
      "type": "string",
      "minLength": 8,
      "maxLength": 1024,
      "pattern": "^/input/(?!\\.{1,2}(?:/|$))(?!.*\\/\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)[^\\u0000]+$"
    },
    "actionReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_id",
        "plugin_version",
        "plugin_digest",
        "action_id"
      ],
      "properties": {
        "plugin_id": {
          "$ref": "#/$defs/pluginId"
        },
        "plugin_version": {
          "$ref": "#/$defs/semver"
        },
        "plugin_digest": {
          "$ref": "#/$defs/digest"
        },
        "action_id": {
          "$ref": "#/$defs/localId"
        }
      }
    },
    "inputFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "path": {
          "$ref": "#/$defs/inputPath"
        },
        "media_type": {
          "$ref": "#/$defs/mimeType"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1099511627776
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "grants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilities"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100,
            "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_ms",
        "memory_mb",
        "output_mb"
      ],
      "properties": {
        "timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900000
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 16,
          "maximum": 8192
        },
        "output_mb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2048
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locale",
        "timezone"
      ],
      "properties": {
        "locale": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    }
  }
}
