{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shejane.dev/schemas/managed-worker-vm-assets-v1.schema.json",
  "title": "SheJane macOS Managed Worker VM asset set v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_set_id",
    "host",
    "guest",
    "protocol_version",
    "files",
    "sources",
    "build",
    "sbom",
    "licenses"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "asset_set_id": {
      "type": "string",
      "pattern": "^darwin-(arm64|amd64)/sha256:[0-9a-f]{64}$"
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch"],
      "properties": {
        "os": { "const": "darwin" },
        "arch": { "enum": ["arm64", "amd64"] }
      }
    },
    "guest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch"],
      "properties": {
        "os": { "const": "linux" },
        "arch": { "enum": ["arm64", "amd64"] }
      }
    },
    "protocol_version": { "const": 1 },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kernel", "initramfs", "rootfs", "mke2fs", "launcher"],
      "properties": {
        "kernel": { "$ref": "#/$defs/file" },
        "initramfs": { "$ref": "#/$defs/file" },
        "rootfs": { "$ref": "#/$defs/file" },
        "mke2fs": { "$ref": "#/$defs/file" },
        "launcher": { "$ref": "#/$defs/file" }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/source" }
    },
    "build": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 64,
      "propertyNames": { "minLength": 1, "maxLength": 100 },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "sbom": { "$ref": "#/$defs/file" },
    "licenses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*\\\\)[^\\u0000]+$"
        },
        "size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8589934592
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "url", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "version": { "type": "string", "minLength": 1, "maxLength": 200 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "signature": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    }
  }
}
