{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:shejane:schema:plugin-manifest:v1",
  "title": "SheJane Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "name",
    "description",
    "publisher",
    "runtime",
    "contributions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "#/$defs/pluginId"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "publisher": {
      "$ref": "#/$defs/publisher"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "contributions": {
      "$ref": "#/$defs/contributions"
    }
  },
  "$defs": {
    "pluginId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
    },
    "localId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "maxLength": 100,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "packagePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!\\.{1,2}(?:/|$))(?!.*\\/\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)[^\\u0000]+$"
    },
    "mimeType": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}$"
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/pluginId"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_version",
        "execution"
      ],
      "properties": {
        "min_version": {
          "$ref": "#/$defs/semver"
        },
        "execution": {
          "oneOf": [
            {
              "$ref": "#/$defs/wasiExecution"
            },
            {
              "$ref": "#/$defs/managedWorkerExecution"
            },
            {
              "$ref": "#/$defs/builtinExecution"
            }
          ]
        }
      }
    },
    "wasiExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "entrypoint",
        "platforms"
      ],
      "properties": {
        "kind": {
          "const": "wasi"
        },
        "entrypoint": {
          "allOf": [
            {
              "$ref": "#/$defs/packagePath"
            },
            {
              "pattern": "\\.wasm$"
            }
          ]
        },
        "platforms": {
          "const": [
            "any"
          ]
        }
      }
    },
    "managedWorkerExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "entrypoint",
        "platforms"
      ],
      "properties": {
        "kind": {
          "const": "managed_worker"
        },
        "entrypoint": {
          "$ref": "#/$defs/packagePath"
        },
        "runtime_assets": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtimeAssetReference"
          }
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "darwin/arm64",
              "darwin/amd64",
              "linux/arm64",
              "linux/amd64",
              "windows/arm64",
              "windows/amd64"
            ]
          }
        }
      }
    },
    "runtimeAssetReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/pluginId"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "builtinExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "handler",
        "platforms"
      ],
      "properties": {
        "kind": {
          "const": "builtin"
        },
        "handler": {
          "const": "computer_use"
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "darwin/arm64"
            ]
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_ms",
        "memory_mb",
        "output_mb"
      ],
      "properties": {
        "timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900000
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 16,
          "maximum": 8192
        },
        "output_mb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2048
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "input_schema",
        "output_schema",
        "consumes",
        "produces",
        "effects",
        "determinism",
        "capabilities",
        "limits"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "input_schema": {
          "$ref": "#/$defs/packagePath"
        },
        "output_schema": {
          "$ref": "#/$defs/packagePath"
        },
        "consumes": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/mimeType"
          }
        },
        "produces": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/mimeType"
          }
        },
        "effects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "read",
              "artifact",
              "external"
            ]
          }
        },
        "determinism": {
          "enum": [
            "pure",
            "input_stable",
            "nondeterministic"
          ]
        },
        "capabilities": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100,
            "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
          }
        },
        "limits": {
          "$ref": "#/$defs/limits"
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "path": {
          "$ref": "#/$defs/packagePath"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "instructions",
        "required_actions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "instructions": {
          "$ref": "#/$defs/packagePath"
        },
        "required_actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/localId"
          }
        }
      }
    },
    "mcpBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "path": {
          "$ref": "#/$defs/packagePath"
        }
      }
    },
    "contributions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions"
      ],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "skills": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/skill"
          }
        },
        "commands": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "mcp_servers": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/mcpBinding"
          }
        }
      }
    }
  }
}
