{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:shejane:schema:plugin-action-result:v1",
  "title": "SheJane Plugin Action Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invocation_id",
    "operation_id",
    "status",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "invocation_id": {
      "$ref": "#/$defs/invocationId"
    },
    "operation_id": {
      "$ref": "#/$defs/operationId"
    },
    "status": {
      "enum": [
        "succeeded",
        "failed"
      ]
    },
    "output": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "error": {
      "$ref": "#/$defs/error"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "output"
        ],
        "not": {
          "required": [
            "error"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "error"
        ],
        "not": {
          "required": [
            "output"
          ]
        }
      }
    }
  ],
  "$defs": {
    "invocationId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "operationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "mimeType": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]{0,127}$"
    },
    "outputPath": {
      "type": "string",
      "minLength": 9,
      "maxLength": 1024,
      "pattern": "^/output/(?!\\.{1,2}(?:/|$))(?!.*\\/\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)[^\\u0000]+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "media_type",
        "name"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/outputPath"
        },
        "media_type": {
          "$ref": "#/$defs/mimeType"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
