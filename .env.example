# ============================================================================
# 石间 / SheJane — environment template (env var prefix `JIANDANLY_` is the legacy code name)
# Copy to `.env` and fill in credentials. Audited 2026-05-21 against actual
# code references (Go / Python / Vite / Electron / scripts / docker-compose).
# ============================================================================


# === A. Shared URLs ===
CLIENT_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
APP_BASE_URL=http://localhost:8080


# === B. API server (Go) ===
HTTP_ADDR=:8080
# Sign cookies + JWTs. MUST be replaced for any non-throwaway deploy.
JWT_SECRET=replace-with-a-long-random-secret
# Set true behind HTTPS so cookies are marked Secure.
COOKIE_SECURE=false
DATABASE_URL=postgres://jiandanly:jiandanly@postgres:5432/jiandanly?sslmode=disable
# Comma-separated emails that get auto-promoted to admin on register/login.
ADMIN_EMAILS=
# Monthly credit grant on the 1st (0 disables); one-time signup bonus.
MONTHLY_CREDITS=20000
SIGNUP_CREDITS=500000
# AES-GCM key (32 bytes hex, no whitespace) for model-registry API keys at
# rest. Empty ⇒ keys are stored plaintext (dev only).
CONFIG_ENCRYPTION_KEY=
# How long completed agent runs are retained before pruning. 0 = never.
AGENT_RUN_TTL_HOURS=168


# === C. Docker host ports ===
# Bumped off common local defaults so a locally-installed Postgres/Redis can
# coexist with the compose stack.
POSTGRES_PORT=15432
REDIS_PORT=16379
CLIENT_PORT=5173
ADMIN_PORT=5174


# === D. LLM providers ===
# When true, the API returns canned responses without calling any LLM.
MOCK_LLM=true

# Fast tier — OpenAI-compatible (DeepSeek recommended for cheap inference).
# *_KIND selects the adapter: "openai" (default), "anthropic", etc.
FAST_PROVIDER_KIND=openai
FAST_PROVIDER_BASE_URL=https://api.deepseek.com
FAST_PROVIDER_API_KEY=
FAST_MODEL=deepseek-v4-flash

# Deep tier — defaults to Anthropic Claude; can be swapped to another
# OpenAI-compatible provider via DEEP_PROVIDER_* below.
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
DEEP_MODEL=claude-3-5-sonnet-latest
DEEP_PROVIDER_KIND=
DEEP_PROVIDER_BASE_URL=
DEEP_PROVIDER_API_KEY=


# === E. Cloud Tool Gateway (Go) ===
# Platform-paid provider keys. MUST stay in the API environment only —
# Local Host / Electron must NOT inherit them (the dev script's env -i
# sandbox enforces this).
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_CREDITS=20
TOOL_GATEWAY_TIMEOUT_MS=15000

# E2B (cloud microVM sandbox) — powers the agent's code.execute tool.
# Empty key disables the tool gracefully (the gateway returns a
# "tool not configured" envelope and the daemon's registry omits it
# from the agent's toolset). Per CLAUDE.md Invariant #1 this key
# MUST live in the API env only — never in the daemon's.
E2B_API_KEY=
E2B_BASE_URL=https://api.e2b.dev
E2B_TEMPLATE_ID=code-interpreter-v1
# 15 min default idle TTL; reaper kills sandboxes that haven't been
# touched in this long. 60 min hard ceiling regardless of activity.
E2B_SANDBOX_IDLE_TTL_SECONDS=900
E2B_SANDBOX_MAX_LIFETIME_SECONDS=3600
# Per-call billing knobs. Worst-case reserve = base + timeout * per_sec;
# actual settle uses ceil(execution_ms/1000) seconds.
E2B_CODE_EXEC_BASE_CREDITS=5
E2B_CODE_EXEC_PER_SECOND_CREDITS=1
E2B_SANDBOX_REQUEST_TIMEOUT_SECONDS=60


# === F. Stripe billing ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=


# === G. S3 documents ===
# Bucket must allow browser PUT from CLIENT_BASE_URL and the API
# read/write/delete via these credentials.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# S3 Transfer Acceleration — routes browser PUT uploads through
# CloudFront edges so cross-border latency drops 3-10×. Especially
# important for users in mainland China uploading to non-CN buckets.
# Setup: enable Transfer Acceleration on the bucket in the AWS Console
# (Properties → Transfer acceleration → Enable). Bucket name must
# contain no dots — DNS-style names only. Costs $0.04/GB on top of
# standard transfer. Default off so an unprepared bucket doesn't
# break.
S3_USE_ACCELERATE=false
S3_DOCUMENT_PREFIX=documents
DOCUMENT_MAX_BYTES=31457280
DOCUMENT_TEXT_LIMIT=60000
DOCUMENT_TTL_HOURS=168


# === H. Frontend (Vite) ===
VITE_API_BASE_URL=http://localhost:8080
# Fallback Local Host pairing token for browser-dev mode (no Electron
# bridge). Inside Electron the token is supplied by preload.cjs from
# JIANDANLY_LOCAL_HOST_TOKEN below.
VITE_JIANDANLY_LOCAL_HOST_TOKEN=


# === I. Local Agent Harness — pairing ===
# Loopback-only daemon. The pairing token is generated per machine in real
# use; an empty token disables the auth header check (dev only).
JIANDANLY_LOCAL_HOST_ADDR=127.0.0.1
JIANDANLY_LOCAL_HOST_PORT=17371
JIANDANLY_LOCAL_HOST_URL=http://127.0.0.1:17371
JIANDANLY_LOCAL_HOST_TOKEN=
# How the daemon reaches the cloud control plane for federated tools.
JIANDANLY_CLOUD_BASE_URL=http://localhost:8080
JIANDANLY_CLOUD_TOKEN=


# === J. Local Agent Harness — middleware tuning ===
# Input guard for prompt-injection / unsafe content. Modes: observe / block.
JIANDANLY_LOCAL_INPUT_GUARD=block
# Plan-first middleware. Modes: off / always / auto (heuristic-driven).
JIANDANLY_PLAN_FIRST=auto
# Mid-loop tool-result critic. Modes: off / watch / nudge / block.
JIANDANLY_LOCAL_TOOL_CRITIC=off
# Reflection critic at end of run. 1/true/yes enables real LLM critic;
# anything else keeps it as stats-only.
JIANDANLY_LOCAL_CRITIC=
# Max tools surfaced to the planner by LLMToolSelectorMiddleware. 0 ⇒
# selector disabled (all tools sent every turn).
JIANDANLY_LOCAL_TOOL_SELECTOR_MAX=0
# Comma-separated fallback models for ModelFallbackMiddleware, format
# "provider:model" each. Empty ⇒ no fallback chain.
JIANDANLY_LOCAL_FALLBACK_MODELS=
# Comma-separated Microsoft Presidio entity types to redact (e.g.
# EMAIL_ADDRESS,PHONE_NUMBER). Empty ⇒ PII middleware not added.
JIANDANLY_LOCAL_PII_REDACT=
# Long-term memory seeds: comma-separated paths to markdown files loaded
# into the BaseStore on startup.
JIANDANLY_LOCAL_MEMORY_PATHS=
# Override the directory the SkillsMiddleware scans for skill manifests.
JIANDANLY_LOCAL_SKILLS_PATH=
# MCP stdio servers, JSON object:
# {"docs":{"command":"node","args":["server.mjs"],"env":{"K":"V"}}}
JIANDANLY_LOCAL_MCP_SERVERS=

# Per-tool provider keys: image.* now proxies through the cloud
# `/api/v1/agent/tools/execute` gateway (the OpenAI key lives in the
# API's model registry, configured via Admin). No tool-side provider
# keys belong in the daemon environment anymore.


# === K. Observability ===
# LangSmith — viewable run tree per agent invocation. Picked up
# automatically by LangChain callbacks when LANGSMITH_TRACING=true.
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Langfuse — alternative open-source tracing. Activated when both keys
# present.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Hard kill-switch for the entire observability layer (structlog + tracing
# callbacks). 1/true/yes ⇒ everything becomes no-op. Useful in benchmarks.
JIANDANLY_DISABLE_OBSERVABILITY=


# === L. Electron ===
# Optional override for the dock-language hint file the dev launcher writes
# (used to keep the macOS dock badge in sync with app locale).
SHEJANE_DOCK_LANG_FILE=
