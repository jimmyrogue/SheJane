# Shared
CLIENT_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
APP_BASE_URL=http://localhost:8080

# API
HTTP_ADDR=:8080
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
DATABASE_URL=postgres://jiandanly:jiandanly@postgres:5432/jiandanly?sslmode=disable
MONTHLY_CREDITS=20000
# Comma-separated emails that should become admins on register/login/refresh.
ADMIN_EMAILS=

# Host ports used by docker compose. They intentionally avoid common local
# PostgreSQL/Redis defaults so local services can keep running.
POSTGRES_PORT=15432
REDIS_PORT=16379
ADMIN_PORT=5174

# Local development can run without external providers. Set this to false when
# testing a real LLM provider locally.
MOCK_LLM=true

# Fast mode: DeepSeek/OpenAI-compatible provider. DeepSeek's current OpenAI
# compatible base URL is https://api.deepseek.com.
FAST_PROVIDER_BASE_URL=https://api.deepseek.com
FAST_PROVIDER_API_KEY=
# DeepSeek still accepts deepseek-chat temporarily, but current docs recommend
# deepseek-v4-flash / deepseek-v4-pro.
FAST_MODEL=deepseek-v4-flash

# Deep mode: Anthropic Claude by default
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
DEEP_MODEL=claude-3-5-sonnet-latest

# Optional deep mode OpenAI-compatible fallback. To use DeepSeek for deep mode,
# set these two values and set DEEP_MODEL=deepseek-v4-pro.
DEEP_PROVIDER_BASE_URL=
DEEP_PROVIDER_API_KEY=

# Stripe Billing Checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Phase 2A document upload and reading. The bucket must allow browser PUT from
# CLIENT_BASE_URL and API read/write/delete with these credentials.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_DOCUMENT_PREFIX=documents
DOCUMENT_MAX_BYTES=31457280
DOCUMENT_TEXT_LIMIT=60000
DOCUMENT_TTL_HOURS=168

# Frontend
VITE_API_BASE_URL=http://localhost:8080
