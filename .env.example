# Shared
CLIENT_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
APP_BASE_URL=http://localhost:8080

# API
HTTP_ADDR=:8080
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
DATABASE_URL=postgres://jiandanly:jiandanly@postgres:5432/jiandanly?sslmode=disable
MONTHLY_CREDITS=20000
# Comma-separated emails that should become admins on register/login/refresh.
ADMIN_EMAILS=

# Host ports used by docker compose. They intentionally avoid common local
# PostgreSQL/Redis defaults so local services can keep running.
POSTGRES_PORT=15432
REDIS_PORT=16379
ADMIN_PORT=5174

# Local development can run without external providers. Set this to false when
# testing a real LLM provider locally.
MOCK_LLM=true

# Fast mode: DeepSeek/OpenAI-compatible provider. Provider kind is optional;
# when omitted, https://api.deepseek.com is inferred as deepseek-v4.
FAST_PROVIDER_KIND=deepseek-v4
FAST_PROVIDER_BASE_URL=https://api.deepseek.com
FAST_PROVIDER_API_KEY=
# DeepSeek still accepts deepseek-chat temporarily, but current docs recommend
# deepseek-v4-flash / deepseek-v4-pro.
FAST_MODEL=deepseek-v4-flash

# Deep mode: Anthropic Claude by default
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
DEEP_MODEL=claude-3-5-sonnet-latest

# Optional deep mode OpenAI-compatible fallback. To use DeepSeek for deep mode,
# set these two values and set DEEP_MODEL=deepseek-v4-pro.
DEEP_PROVIDER_KIND=
DEEP_PROVIDER_BASE_URL=
DEEP_PROVIDER_API_KEY=

# Stripe Billing Checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Phase 2A document upload and reading. The bucket must allow browser PUT from
# CLIENT_BASE_URL and API read/write/delete with these credentials.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_DOCUMENT_PREFIX=documents
DOCUMENT_MAX_BYTES=31457280
DOCUMENT_TEXT_LIMIT=60000
DOCUMENT_TTL_HOURS=168
AGENT_RUN_TTL_HOURS=168

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Phase 2.3 Local Agent Harness. The daemon binds loopback only. The token is
# local pairing material and should be generated per machine/session in real use.
JIANDANLY_LOCAL_HOST_URL=http://127.0.0.1:17371
JIANDANLY_LOCAL_HOST_PORT=17371
JIANDANLY_LOCAL_HOST_TOKEN=
JIANDANLY_LOCAL_HOST_DB=
JIANDANLY_LOCAL_HOST_DEBUG=
# Optional maximum model/tool-loop turns before the harness asks the model to
# finalize without more tools. Empty/0 means no hard step cap, matching Claude
# Code-style interactive runs.
JIANDANLY_LOCAL_MAX_STEPS=
# Emit a soft long-running warning every N tool-use turns without stopping the
# run. Set 0 to disable.
JIANDANLY_LOCAL_STEP_WARNING_INTERVAL=20
JIANDANLY_CLOUD_BASE_URL=http://localhost:8080
JIANDANLY_CLOUD_ACCESS_TOKEN=
# Phase 2.17 managed browser. Chromium is installed explicitly with
# `cd local-host && npm run browser:install`.
JIANDANLY_BROWSER_ENGINE=playwright
JIANDANLY_BROWSER_HEADLESS=true
JIANDANLY_BROWSER_TIMEOUT_MS=15000
JIANDANLY_BROWSER_SEARCH_URL=https://cn.bing.com/search?q={query}
# Keep true for local proxy/TUN fake-ip DNS such as Clash 198.18.0.0/15.
JIANDANLY_ALLOW_PROXY_FAKE_IPS=true
# Phase 2.6+ local web and MCP tooling. Tavily is optional; when absent,
# web.search returns a recoverable disabled-tool observation. MCP tools require
# both an allowlist entry and a local stdio server config.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
JIANDANLY_MCP_ALLOWLIST=
# JSON object: {"local-docs":{"command":"node","args":["/path/to/server.mjs"],"env":{"KEY":"value"}}}
JIANDANLY_MCP_SERVERS_JSON=
