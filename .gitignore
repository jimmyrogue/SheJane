# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Local agent/tooling scratch
# `.claude/` itself is mostly local — but the SUBSET that's team-shared
# automation (skills, agents, hooks config, MCP config) needs to be
# tracked. Pattern: ignore everything, then explicitly un-ignore the
# pieces the team owns. settings.local.json + auth tokens / scratch
# dirs continue to be ignored.
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
# `.mcp.json` lives at repo root, NOT under .claude/, so it's tracked
# by default — no re-include needed here.
.codex/

# Environment and secrets
.env
.env.*
!.env.example
!**/.env.example

# Logs and runtime temp files
*.log
logs/
tmp/
temp/
.tmp/
.cache/

# Node / Vite / React
node_modules/
**/node_modules/
dist/
**/dist/
build/
**/build/
# Exception: electron-builder's build-resources dir holds the NSIS installer
# customization (committed source, not a build artifact). Re-include just that file.
!client/build/
client/build/*
!client/build/installer.nsh
!client/build/managed-worker-vm.entitlements.plist
.vite/
**/.vite/
.turbo/
.parcel-cache/
coverage/
**/coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Electron packaging output
release/
out/
*.asar
*.dmg
*.pkg
*.AppImage
*.exe

# Generated plugin packages
*.shejane-plugin
*.shejane-plugin.tmp
!runtime/plugins/fixtures/wasi-archive/.shejane-plugin/
!runtime/plugins/fixtures/wasi-archive/.shejane-plugin/plugin.json

# Python / uv
.venv/
*.egg-info/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
# Runtime spill cache — when a tool result exceeds the in-memory cap
# (e.g. web.fetch returning a large HTML body), LangGraph writes it
# to disk under this dir keyed by tool_call_id. Pure local cache,
# safe to delete, regenerated on demand.
runtime/large_tool_results/

# Local databases and generated data
*.db
*.sqlite
*.sqlite3

# PyInstaller intermediate build dir for the frozen runtime (dist/ already ignored)
runtime/build/
