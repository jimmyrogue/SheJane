# Python / uv
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
# Daemon spill cache — when a tool result exceeds the in-memory cap
# (e.g. web.fetch returning a large HTML body), LangGraph writes it
# to disk under this dir keyed by tool_call_id. Pure local cache,
# safe to delete, regenerated on demand.
local-host/python/large_tool_results/

# Local databases and generated data
*.db
*.sqlite
*.sqlite3
postgres-data/

# Docker / deployment local overrides
docker-compose.override.yml
Caddyfile.local

# Local Postgres dumps from `make deploy-backup` — never commit DB data
backup-*.sql.gz

# PyInstaller intermediate build dir for the frozen daemon (dist/ already ignored)
local-host/python/build/
