{
  "name": "@shejane/client",
  "productName": "石间",
  "version": "0.1.15",
  "private": true,
  "description": "SheJane (石间) desktop client — Electron + React agentic chat UI.",
  "license": "AGPL-3.0-only",
  "author": "TAO LIANG <tliang92@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimmyrogue/SheJane",
    "directory": "client"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "pnpm --filter @shejane/runtime-sdk build",
    "prebuild": "pnpm --filter @shejane/runtime-sdk build",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "pretest": "pnpm --filter @shejane/runtime-sdk build",
    "test": "vitest",
    "pretest:contract": "pnpm --filter @shejane/runtime-sdk build",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:e2e:client": "playwright test --config playwright.config.ts",
    "electron": "./electron/run-dev.sh electron/main.cjs",
    "build:client": "pnpm --filter @shejane/runtime-sdk build && tsc -b && vite build",
    "dist": "pnpm build:client && electron-builder",
    "dist:dir": "pnpm build:client && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.65",
    "@fontsource-variable/geist": "^5.2.8",
    "@lexical/react": "^0.44.0",
    "@shejane/runtime-sdk": "workspace:*",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "lexical": "^0.44.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "read-excel-file": "^9.3.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-normalize-headings": "^4.0.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
