  "info": {
    "title": "Jiandanly Local Host",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/local/v1/artifacts/{artifact_id}": {
      "get": {
        "description": "Return a single artifact record.\n\nShape matches the TS `LocalArtifact` interface\n(`client.ts:38-44`): `{id, title, content, tool_name?, created_at?}`.",
        "operationId": "get_artifact_local_v1_artifacts__artifact_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "artifact_id",
            "required": true,
            "schema": {
              "title": "Artifact Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocalArtifact"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Artifact"
      }
    },
    "/local/v1/health": {
      "get": {
        "operationId": "health_local_v1_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/local/v1/permissions/{permission_id}": {
      "post": {
        "description": "Approve / deny a pending tool-permission request.\n\nTranslates the client's `{decision, scope}` body into the\n`{\"decisions\": [{\"type\": \"approve\"|\"reject\", ...}]}` shape\nthat `HumanInTheLoopMiddleware` expects on resume (the\nmiddleware does `interrupt(...)[\"decisions\"]` and KeyError's\non anything else).\n\nWhen `scope=run`, the coordinator caches the tool name so the\nauto-approve loop in `_drive_run` skips re-prompting on\nsubsequent gates for the same tool in the same run.",
        "operationId": "resolve_permission_local_v1_permissions__permission_id__post",
        "parameters": [
          {
            "in": "path",
            "name": "permission_id",
            "required": true,
            "schema": {
              "title": "Permission Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolvePermissionRequest"
