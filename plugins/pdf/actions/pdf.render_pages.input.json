{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["input_id", "pages", "dpi"],
  "properties": {
    "input_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 1, "maximum": 100000}
    },
    "dpi": {"type": "integer", "minimum": 72, "maximum": 300}
  }
}
