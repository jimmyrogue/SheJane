{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["page_count", "dpi", "pages"],
  "properties": {
    "page_count": {"type": "integer", "minimum": 1, "maximum": 100000},
    "dpi": {"type": "integer", "minimum": 72, "maximum": 300},
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["page_number", "artifact_name"],
        "properties": {
          "page_number": {"type": "integer", "minimum": 1, "maximum": 100000},
          "artifact_name": {"type": "string", "pattern": "^page-[0-9]{4,6}\\.png$"}
        }
      }
    }
  }
}
