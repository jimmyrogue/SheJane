{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["slide_count", "rendered_slides", "pdf_name", "png_names", "unsupported_features", "warnings"],
  "properties": {
    "slide_count": {"type": "integer", "minimum": 1},
    "rendered_slides": {"type": "integer", "minimum": 0, "maximum": 200},
    "pdf_name": {"type": "string", "minLength": 5, "maxLength": 255},
    "png_names": {"type": "array", "maxItems": 200, "items": {"type": "string", "minLength": 1, "maxLength": 255}},
    "unsupported_features": {"type": "array", "uniqueItems": true, "maxItems": 3, "items": {"enum": ["animations", "transitions", "audio_or_video"]}},
    "warnings": {"type": "array", "maxItems": 100, "items": {"type": "string", "maxLength": 500}}
  }
}
