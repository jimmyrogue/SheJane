{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["filename", "blocks"],
  "properties": {
    "filename": {"type": "string", "minLength": 6, "maxLength": 255, "pattern": "^[^/\\\\]+\\.docx$"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "maxLength": 1000},
        "author": {"type": "string", "maxLength": 1000},
        "subject": {"type": "string", "maxLength": 1000},
        "keywords": {"type": "string", "maxLength": 1000}
      }
    },
    "header": {"type": "string", "maxLength": 10000},
    "footer": {"type": "string", "maxLength": 10000},
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "oneOf": [
          {
            "type": "object", "additionalProperties": false, "required": ["type", "text"],
            "properties": {"type": {"const": "paragraph"}, "text": {"type": "string", "maxLength": 100000}, "style": {"type": "string", "minLength": 1, "maxLength": 100}}
          },
          {
            "type": "object", "additionalProperties": false, "required": ["type", "text", "level"],
            "properties": {"type": {"const": "heading"}, "text": {"type": "string", "maxLength": 10000}, "level": {"type": "integer", "minimum": 1, "maximum": 9}}
          },
          {
            "type": "object", "additionalProperties": false, "required": ["type", "items"],
            "properties": {"type": {"enum": ["bullet_list", "numbered_list"]}, "items": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"type": "string", "maxLength": 10000}}}
          },
          {
            "type": "object", "additionalProperties": false, "required": ["type", "rows"],
            "properties": {"type": {"const": "table"}, "rows": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"type": "string", "maxLength": 10000}}}}
          },
          {
            "type": "object", "additionalProperties": false, "required": ["type"],
            "properties": {"type": {"const": "page_break"}}
          }
        ]
      }
    }
  }
}
