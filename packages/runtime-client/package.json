{
  "name": "@shejane/runtime-client",
  "version": "0.1.0",
  "description": "TypeScript client for the SheJane Harness Runtime HTTP protocol.",
  "license": "AGPL-3.0-only",
  "author": "TAO LIANG <tliang92@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimmyrogue/SheJane",
    "directory": "packages/runtime-client"
  },
  "type": "module",
  "files": [
    "dist",
    "src/generated.d.ts",
    "openapi.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generated": {
      "types": "./src/generated.d.ts"
    },
    "./openapi.json": "./openapi.json"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "openapi-typescript openapi.json -o src/generated.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.2"
  }
}
