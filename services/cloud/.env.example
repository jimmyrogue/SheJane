# Required service configuration
SHEJANE_ENV=production
DATABASE_URL=postgres://shejane:change-me@localhost:5432/shejane?sslmode=disable
JWT_SECRET=change-me
CONFIG_ENCRYPTION_KEY=change-me
ADMIN_EMAILS=

# Public service endpoints
APP_BASE_URL=https://api.example.com
ADMIN_BASE_URL=https://admin.example.com

# Optional email
RESEND_API_KEY=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=SheJane

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional object storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Optional Cloud tools
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
E2B_API_KEY=
E2B_BASE_URL=https://api.e2b.dev

# Optional observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
