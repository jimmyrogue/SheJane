jiandanly.com {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy client:80
  }
}

admin.jiandanly.com {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy admin:80
  }
}
