# Reverse proxy + TLS for the production stack (docker-compose.prod.yml)
# and the optional dev `proxy` profile (docker-compose.yml).
#
# Domains come from the environment so one file works everywhere:
#   • prod: APP_DOMAIN / ADMIN_DOMAIN are set from .env → real domains,
#     Caddy auto-provisions Let's Encrypt TLS on first request.
#   • dev / unset: fall back to localhost / admin.localhost (Caddy uses
#     its internal CA).
#
# Each site serves the SPA at the root and proxies /api/* + /health to
# the api container — so the client/admin images can be built with an
# empty VITE_API_BASE_URL and issue relative, same-origin requests.

# Global options. The ACME contact email receives Let's Encrypt
# expiry / renewal-failure notifications. Override per-deploy with the
# ACME_EMAIL env var; ignored for the localhost internal-CA fallback.
{
	email {$ACME_EMAIL:tliang92@gmail.com}
}

{$APP_DOMAIN:localhost} {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy client:80
  }
}

{$ADMIN_DOMAIN:admin.localhost} {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy admin:80
  }
}
