# Reverse proxy + TLS for the production stack (docker-compose.prod.yml)
# and the optional dev `proxy` profile (docker-compose.yml).
#
# Domains come from the environment so one file works everywhere:
#   • prod: APP_DOMAIN / ADMIN_DOMAIN are set from .env → real domains,
#     Caddy auto-provisions Let's Encrypt TLS on first request.
#   • dev / unset: fall back to localhost / admin.localhost (Caddy uses
#     its internal CA).
#
# Each site serves the SPA at the root and proxies /api/* + /health to
# the api container — so the client/admin images can be built with an
# empty VITE_API_BASE_URL and issue relative, same-origin requests.

# Global options. The ACME contact email receives Let's Encrypt
# expiry / renewal-failure notifications. Override per-deploy with the
# ACME_EMAIL env var; ignored for the localhost internal-CA fallback.
{
	email {$ACME_EMAIL:admin@example.com}
}

(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; worker-src 'self' blob:; media-src 'self' blob: data:; form-action 'self'"
    X-Frame-Options "DENY"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), geolocation=(), microphone=()"
  }
}

{$APP_DOMAIN:localhost} {
  import security_headers
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  # Liveness + readiness probes also live on the API (the readiness probe
  # pings the DB). Without these, external uptime monitors hitting /readyz
  # would fall through to the SPA and always see 200.
  handle /healthz {
    reverse_proxy api:8080
  }

  handle /readyz {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy client:80
  }
}

{$ADMIN_DOMAIN:admin.localhost} {
  import security_headers
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8080
  }

  handle /health {
    reverse_proxy api:8080
  }

  # Liveness + readiness probes also live on the API (the readiness probe
  # pings the DB). Without these, external uptime monitors hitting /readyz
  # would fall through to the SPA and always see 200.
  handle /healthz {
    reverse_proxy api:8080
  }

  handle /readyz {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy admin:80
  }
}
